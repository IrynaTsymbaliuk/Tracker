<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network permission required for fetching Letterboxd RSS feeds -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Health Connect: required to read StepsRecord via HealthConnectStepCollector -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />

    <!--
        Package visibility queries for Android 11+ (API 30+)
        Declares which apps this library needs to detect.
        Required for getInstalledApplications() to return language learning apps.
    -->
    <queries>
        <!-- Language Learning Apps -->
        <package android:name="com.mindtwisted.kanjistudy" />
        <package android:name="com.lulilanguages.j5a" />
        <package android:name="com.ichi2.anki" />
        <package android:name="com.eup.mytest" />
        <package android:name="mobi.eup.jpnews" />
        <package android:name="com.duolingo" />
        <package android:name="com.eup.heyjapan" />
        <package android:name="com.appsci.tenwords" />
        <package android:name="com.languagedrops.drops.international" />
        <package android:name="com.languagedrops.drops.learn.learning.speak.language.japanese.kanji.katakana.hiragana.romaji.words" />
        <package android:name="com.lingodeer" />
        <package android:name="com.lulilanguages.j5KjAnd" />
        <package android:name="com.renshuu.renshuu_org" />

        <!-- Reading Apps -->
        <package android:name="com.google.android.apps.books" />
        <package android:name="com.amazon.kindle" />

        <!-- Health Connect -->
        <package android:name="com.google.android.apps.healthdata" />

        <!-- Social Media Apps -->
        <package android:name="com.facebook.katana" />
        <package android:name="com.instagram.android" />
        <package android:name="com.twitter.android" />
        <package android:name="com.zhiliaoapp.musically" />
        <package android:name="com.snapchat.android" />
        <package android:name="com.linkedin.android" />
        <package android:name="com.reddit.frontpage" />
        <package android:name="com.pinterest" />
        <package android:name="com.whatsapp" />
        <package android:name="org.telegram.messenger" />
        <package android:name="com.discord" />
        <package android:name="com.instagram.barcelona" />
        <package android:name="org.joinmastodon.android" />
        <package android:name="xyz.blueskyweb.app" />
        <package android:name="com.tumblr" />
    </queries>

</manifest>
